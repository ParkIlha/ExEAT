FLASK_PORT=5001
# 회원 토큰 서명용 — 배포 시 반드시 강한 값으로 변경
JWT_SECRET=change-me-in-production

# OAuth 로그인 콜백에서 사용할 프론트 URL (개발 기본값: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here
GEMINI_API_KEY=your_gemini_api_key_here

# Kakao / Naver 소셜 로그인 (REST / OAuth)
KAKAO_CLIENT_ID=your_kakao_rest_api_key_here
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here
NAVER_OAUTH_CLIENT_ID=your_naver_login_client_id_here
NAVER_OAUTH_CLIENT_SECRET=your_naver_login_client_secret_here
